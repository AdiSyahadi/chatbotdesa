# Root-level gitignore for monorepo

# Environment files (contain secrets)
.env
!.env.docker
!.env.example

# SQL dumps
*.sql

# Misc text files
pashe.txt
cararunredis.txt
saran dari temen saya.txt

# Backup files
*.bak

# Docker volumes (if mapped locally)
mysql_data/
redis_data/

# OS
.DS_Store
Thumbs.db

# Embedded git repo (separate project)
security-agent/
