  "webhook_payloads": {
    "description": "Webhook payload format sent to client URLs",
    "common_fields": {
      "event": "string, event type",
      "timestamp": "ISO datetime",
      "instance_id": "uuid",
      "organization_id": "uuid"
    },
    "events": {
      "message.received": {
        "description": "Incoming message from WhatsApp",
        "payload": {
          "event": "message.received",
          "timestamp": "2026-02-05T10:30:00Z",
          "instance_id": "uuid",
          "data": {
            "message_id": "BAE5xxxx",
            "from": "62812xxx@s.whatsapp.net",
            "from_name": "John Doe",
            "type": "TEXT",
            "content": "Hello!",
            "media_url": "null or URL",
            "timestamp": "2026-02-05T10:30:00Z"
          }
        }
      },
      "message.sent": {
        "description": "Outgoing message status update",
        "payload": {
          "event": "message.sent",
          "timestamp": "2026-02-05T10:30:05Z",
          "instance_id": "uuid",
          "data": {
            "message_id": "uuid (our ID)",
            "wa_message_id": "BAE5xxxx",
            "to": "62812xxx@s.whatsapp.net",
            "status": "SENT"
          }
        }
      },
      "message.delivered": {
        "payload": {
          "event": "message.delivered",
          "data": {
            "message_id": "uuid",
            "wa_message_id": "BAE5xxxx",
            "status": "DELIVERED"
          }
        }
      },
      "message.read": {
        "payload": {
          "event": "message.read",
          "data": {
            "message_id": "uuid",
            "wa_message_id": "BAE5xxxx",
            "status": "READ"
          }
        }
      },
      "message.failed": {
        "payload": {
          "event": "message.failed",
          "data": {
            "message_id": "uuid",
            "error": "Number not on WhatsApp"
          }
        }
      },
      "connection.update": {
        "description": "Instance connection status changed",
        "payload": {
          "event": "connection.update",
          "timestamp": "2026-02-05T10:30:00Z",
          "instance_id": "uuid",
          "data": {
            "status": "CONNECTED|DISCONNECTED|QR_READY",
            "phone_number": "62812xxx or null",
            "reason": "logout|banned|connection_lost"
          }
        }
      },
      "qr.update": {
        "description": "New QR code generated",
        "payload": {
          "event": "qr.update",
          "data": {
            "qr_code": "base64 image"
          }
        }
      }
    },
    "signature_verification": {
      "description": "Verify webhook authenticity",
      "header": "X-Webhook-Signature",
      "algorithm": "HMAC-SHA256",
      "verification": "const expectedSignature = crypto.createHmac('sha256', webhookSecret).update(JSON.stringify(payload)).digest('hex'); const isValid = signature === expectedSignature;"
    }
  },

  "baileys_events": {
    "description": "Baileys library events to handle",
    "events": {
      "connection.update": {
        "description": "Connection state changed",
        "states": ["open", "close", "connecting"],
        "handle": "Update instance status, trigger webhook"
      },
      "creds.update": {
        "description": "Session credentials updated",
        "handle": "Save to database, backup session"
      },
      "messages.upsert": {
        "description": "New message received/sent",
        "types": ["notify", "append"],
        "handle": "Save message, trigger webhook"
      },
      "messages.update": {
        "description": "Message status updated (delivered, read)",
        "handle": "Update message status, trigger webhook"
      },
      "messages.delete": {
        "description": "Message deleted",
        "handle": "Mark message as deleted"
      },
      "presence.update": {
        "description": "Contact presence (online, typing)",
        "handle": "Optional - forward to webhook"
      },
      "contacts.upsert": {
        "description": "New contacts synced",
        "handle": "Save/update contacts"
      },
      "contacts.update": {
        "description": "Contact info updated",
        "handle": "Update contact"
      },
      "groups.upsert": {
        "description": "Group info",
        "handle": "Save group as contact"
      }
    }
  },

  "anti_ban_strategy": {
    "description": "Built-in protection against WhatsApp bans",
    "warming_phases": {
      "DAY_1_3": {
        "daily_limit": 10,
        "delay_min_ms": 10000,
        "delay_max_ms": 30000
      },
      "DAY_4_7": {
        "daily_limit": 30,
        "delay_min_ms": 5000,
        "delay_max_ms": 15000
      },
      "DAY_8_14": {
        "daily_limit": 100,
        "delay_min_ms": 3000,
        "delay_max_ms": 8000
      },
      "DAY_15_PLUS": {
        "daily_limit": 300,
        "delay_min_ms": 2000,
        "delay_max_ms": 5000
      }
    },
    "health_score_factors": {
      "account_age": "+20 for > 7 days",
      "daily_limit_usage": "-10 if > 80%",
      "message_failures": "-5 per failure",
      "reported_by_users": "-20 per report",
      "business_account": "+10"
    },
    "auto_pause": {
      "trigger": "health_score < 30",
      "action": "Pause sending, notify user"
    }
  },

