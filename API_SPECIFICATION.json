        },
        {
          "method": "PATCH",
          "path": "/members/:id/role",
          "description": "Change member role",
          "roles": ["ORG_OWNER"]
        },
        {
          "method": "DELETE",
          "path": "/members/:id",
          "description": "Remove team member",
          "roles": ["ORG_OWNER"]
        }
      ]
    },

    "templates": {
      "base": "/api/templates",
      "endpoints": [
        {
          "method": "GET",
          "path": "/",
          "description": "List message templates"
        },
        {
          "method": "POST",
          "path": "/",
          "description": "Create template",
          "request": {
            "body": {
              "name": "string, required",
              "category": "string, optional",
              "message_type": "TEXT|IMAGE|VIDEO|DOCUMENT",
              "content": "string, required, can include {{variable}}",
              "media_url": "string, optional",
              "caption": "string, optional"
            }
          }
        },
        {
          "method": "GET",
          "path": "/:id",
          "description": "Get template"
        },
        {
          "method": "PATCH",
          "path": "/:id",
          "description": "Update template"
        },
        {
          "method": "DELETE",
          "path": "/:id",
          "description": "Delete template"
        }
      ]
    },

    "billing": {
      "base": "/api/billing",
      "endpoints": [
        {
          "method": "GET",
          "path": "/subscription",
          "description": "Get current subscription"
        },
        {
          "method": "GET",
          "path": "/plans",
          "description": "List available plans"
        },
        {
          "method": "POST",
          "path": "/subscribe",
          "description": "Subscribe to plan",
          "request": {
            "body": {
              "plan_id": "uuid, required"
            }
          }
        },
        {
          "method": "POST",
          "path": "/cancel",
          "description": "Cancel subscription"
        },
        {
          "method": "GET",
          "path": "/invoices",
          "description": "List invoices"
        },
        {
          "method": "GET",
          "path": "/invoices/:id",
          "description": "Get invoice details"
        },
        {
          "method": "POST",
          "path": "/invoices/:id/pay",
          "description": "Pay invoice (redirect to Midtrans or show bank details)"
        },
        {
          "method": "POST",
          "path": "/invoices/:id/upload-proof",
          "description": "Upload payment proof for manual transfer",
          "request": {
            "content_type": "multipart/form-data",
